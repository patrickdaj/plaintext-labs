	@echo "  HR/Users          (9 users)"
	@echo "  HR/Computers      (5 workstations)"
	@echo "Service Accounts/   (6 service accounts)"
	@echo ""
	@echo "--- High-Privilege Groups ---"
	@echo "Domain Admins:     tallen, Administrator"
	@echo "IT-Admins:         tallen, sgarcia, pmartinez, svc-deploy"
	@echo "Backup-Operators:  svc-backup"
	@echo ""
	@echo "--- Kerberoastable SPNs ---"
	@echo "svc-mssql   MSSQLSvc/db01.meridian.local:1433  (password age: 2yr)"
	@echo "svc-backup  BackupSvc/backup01.meridian.local  (password age: 18mo)"
	@echo "svc-web     HTTP/intranet.meridian.local        (password age: 6mo)"
	@echo ""
	@echo "--- AS-REP Roastable (no preauth) ---"
	@echo "svc-legacy   (password age: 3yr)"
	@echo "svc-monitor  (password age: 1yr)"
	@echo ""
	@echo "--- ACL Misconfigurations ---"
	@echo "svc-deploy      -> GenericWrite on IT-Admins group"
	@echo "Finance-Managers -> GenericWrite on Finance-Users group"
	@echo "Helpdesk-Staff  -> Password reset rights on Finance and HR OUs"
	@echo ""
