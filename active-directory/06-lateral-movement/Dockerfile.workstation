FROM debian:bookworm-slim

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    samba \
    smbclient \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

COPY data/workstation-smb.conf /etc/samba/smb.conf

# Create a test share directory
RUN mkdir -p /srv/share && echo "Meridian workstation share" > /srv/share/readme.txt

EXPOSE 139 445

CMD ["smbd", "--foreground", "--no-process-group", "--debuglevel=0"]
